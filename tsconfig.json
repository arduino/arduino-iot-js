{
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "lib": ["es2019", "dom"],
    "outDir": "./dist",
    "declaration": true,
    "declarationDir": "./dist",
    "target": "es2019",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "module": "esnext",
    "moduleResolution": "node",
    "skipLibCheck": true,
    "types": ["node"]
  }
}
