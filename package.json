{
  "name": "arduino-iot-js",
  "version": "0.14.2",
  "license": "GPLv3",
  "description": "JS module providing Arduino Create IoT Cloud Connection",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@arduino/cbor-js": "arduino/cbor-js",
    "rxjs": "^6.5.5"
  },
  "peerDependencies": {
    "mqtt": "^4.3.7"
  },
  "peerDependenciesMeta": {
    "mqtt": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "mqtt": "^4.3.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.61.1",
    "unplugin-dts": "^1.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf node_modules dist",
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "packageManager": "pnpm@10.22.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arduino/arduino-iot-js.git"
  },
  "keywords": [
    "arduino",
    "create",
    "cloud",
    "plugin",
    "iot"
  ],
  "contributors": [
    "Fabrizio Mirabito <f.mirabito@arduino.cc>",
    "Francesco Pirrotta (pirropirro) <f.pirrotta@arduino.cc>"
  ]
}
