{
  "name": "arduino-iot-js",
  "version": "0.14.2",
  "license": "GPLv3",
  "description": "JS module providing Arduino Create IoT Cloud Connection",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@arduino/cbor-js": "arduino/cbor-js",
    "mqtt": "^4.3.7",
    "rxjs": "^6.5.5"
  },
  "devDependencies": {
    "@types/mqtt": "^2.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^2.25.0",
    "@typescript-eslint/parser": "^2.25.0",
    "eslint": "^6.8.0",
    "eslint-config-prettier": "^6.10.1",
    "eslint-plugin-prettier": "^3.1.2",
    "prettier": "^2.0.5",
    "rimraf": "^3.0.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.0",
    "unplugin-dts": "^1.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rimraf dist",
    "build": "pnpm run clean && vite build",
    "dev": "vite build --watch"
  },
  "packageManager": "pnpm@10.22.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arduino/arduino-iot-js.git"
  },
  "keywords": [
    "arduino",
    "create",
    "cloud",
    "plugin",
    "iot"
  ],
  "contributors": [
    "Fabrizio Mirabito <f.mirabito@arduino.cc>",
    "Francesco Pirrotta (pirropirro) <f.pirrotta@arduino.cc>"
  ]
}
